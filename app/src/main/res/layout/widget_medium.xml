<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/widget_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/widget_streak_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🔥 5 hari"
            android:textSize="18sp"
            android:textColor="@android:color/white"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_water_progress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💧 1.2L"
            android:textSize="14sp"
            android:textColor="#81D4FA" />
    </LinearLayout>

    <TextView
        android:id="@+id/widget_today_progress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="✅ 3/5 kebiasaan selesai"
        android:textSize="13sp"
        android:textColor="#B0BEC5" />

    <LinearLayout
        android:id="@+id/widget_habit_list"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:orientation="vertical" />

    <TextView
        android:id="@+id/widget_date"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="14 Juli 2026"
        android:textSize="10sp"
        android:textColor="#78909C" />

</LinearLayout>
