<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.HabitSehat" parent="android:Theme.Material.Light.NoActionBar">
        <!-- Light Theme Colors -->
        <item name="android:colorPrimary">@color/md_theme_light_primary</item>
        <item name="android:colorAccent">@color/md_theme_light_secondary</item>
        <item name="android:colorBackground">@color/md_theme_light_background</item>
        <item name="android:colorForeground">@color/md_theme_light_onBackground</item>

        <!-- Status Bar -->
        <item name="android:statusBarColor">@color/md_theme_light_surface</item>
        <item name="android:windowLightStatusBar">true</item>

        <!-- Navigation Bar -->
        <item name="android:navigationBarColor">@color/md_theme_light_surface</item>
        <item name="android:windowLightNavigationBar">true</item>

        <!-- Text Colors -->
        <item name="android:textColorPrimary">@color/md_theme_light_onSurface</item>
        <item name="android:textColorSecondary">@color/md_theme_light_onSurfaceVariant</item>

        <!-- M3 Attributes -->
        <item name="colorPrimary">@color/md_theme_light_primary</item>
        <item name="colorSecondary">@color/md_theme_light_secondary</item>
        <item name="colorTertiary">@color/md_theme_light_tertiary</item>
        <item name="colorError">@color/md_theme_light_error</item>
        <item name="colorSurface">@color/md_theme_light_surface</item>
    </style>

    <style name="Theme.HabitSehat.Dark" parent="android:Theme.Material.NoActionBar">
        <!-- Dark Theme Colors -->
        <item name="android:colorPrimary">@color/md_theme_dark_primary</item>
        <item name="android:colorAccent">@color/md_theme_dark_secondary</item>
        <item name="android:colorBackground">@color/md_theme_dark_background</item>
        <item name="android:colorForeground">@color/md_theme_dark_onBackground</item>

        <!-- Status Bar -->
        <item name="android:statusBarColor">@color/md_theme_dark_surface</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Navigation Bar -->
        <item name="android:navigationBarColor">@color/md_theme_dark_surface</item>
        <item name="android:windowLightNavigationBar">false</item>

        <!-- Text Colors -->
        <item name="android:textColorPrimary">@color/md_theme_dark_onSurface</item>
        <item name="android:textColorSecondary">@color/md_theme_dark_onSurfaceVariant</item>

        <!-- M3 Attributes -->
        <item name="colorPrimary">@color/md_theme_dark_primary</item>
        <item name="colorSecondary">@color/md_theme_dark_secondary</item>
        <item name="colorTertiary">@color/md_theme_dark_tertiary</item>
        <item name="colorError">@color/md_theme_dark_error</item>
        <item name="colorSurface">@color/md_theme_dark_surface</item>
    </style>

    <!-- Button Styles -->
    <style name="AppButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="cornerRadius">8dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:paddingLeft">24dp</item>
        <item name="android:paddingRight">24dp</item>
        <item name="android:minHeight">48dp</item>
    </style>

    <!-- Card Styles -->
    <style name="AppCard" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">8dp</item>
        <item name="cardElevation">2dp</item>
        <item name="cardBackgroundColor">@color/md_theme_light_surface</item>
    </style>

    <!-- Text Styles -->
    <style name="AppText.HeadlineLarge">
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/md_theme_light_onSurface</item>
    </style>

    <style name="AppText.BodyLarge">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/md_theme_light_onSurface</item>
    </style>

    <style name="AppText.BodySmall">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/md_theme_light_onSurfaceVariant</item>
    </style>
</resources>
